# ── WhatsApp Owner ────────────────────────────────────────────────────────────
# Your WhatsApp number (digits only, no + or spaces)
OWNER_WA_JID=2348012345678

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TG_BOT_TOKEN=1234567890:ABCDefgh...
# Get from @userinfobot on Telegram
OWNER_TG_ID=123456789

# ── MongoDB ───────────────────────────────────────────────────────────────────
# No-auth local (simpler, fine for private VPS):
MONGO_URI=mongodb://127.0.0.1:27017/PappyUltimate2
# With auth (recommended for production):
# MONGO_URI=mongodb://pappybot:YOUR_PASSWORD@127.0.0.1:27017/PappyUltimate2?authSource=admin
MONGO_DB_NAME=PappyUltimate2
MONGO_USER=
MONGO_PASSWORD=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_REQUIRE_AUTH=false

# ── AI (at least one key recommended) ────────────────────────────────────────
# DigitalOcean AI — free tier at cloud.digitalocean.com → API → Tokens
DIGITALOCEAN_AI_KEY=

# OpenRouter — free tier at openrouter.ai → Keys
OPENROUTER_API_KEY=

# Azure OpenAI (optional)
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_CHAT_MODEL=gpt-4o
AZURE_OPENAI_FALLBACK_MODEL=DeepSeek-V3-0324
AZURE_OPENAI_FAST_MODEL=DeepSeek-V3-0324

# ── Session Secret ────────────────────────────────────────────────────────────
SESSION_SECRET=change_this_to_a_long_random_string
